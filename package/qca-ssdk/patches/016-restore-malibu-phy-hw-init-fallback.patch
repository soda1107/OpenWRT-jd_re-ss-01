+static sw_error_t
+hsl_malibu_phy_hw_init_fallback(a_uint32_t dev_id, a_uint32_t malibu_port_bmp)
+{
+	a_uint32_t port_id = 0, phy_addr = 0, first_phy_addr = MAX_PHY_ADDR;
+	a_uint32_t phy_cnt = 0, eee_adv = 0;
+	sw_error_t rv = SW_OK;
+
+	if (!malibu_port_bmp)
+		return SW_OK;
+
+	for (port_id = 0; port_id < SW_MAX_NR_PORT; port_id++)
+	{
+		if (!(malibu_port_bmp & BIT(port_id)))
+			continue;
+
+		phy_cnt++;
+		phy_addr = qca_ssdk_port_to_phy_addr(dev_id, port_id);
+		if (phy_addr < first_phy_addr)
+			first_phy_addr = phy_addr;
+
+		eee_adv = MALIBU_PHY_EEE_ADV_100M | MALIBU_PHY_EEE_ADV_1000M;
+		rv |= hsl_phy_modify_mmd(dev_id, phy_addr, A_FALSE,
+			MALIBU_PHY_MMD7_NUM, MALIBU_PHY_MMD7_ADDR_8023AZ_EEE_CTRL,
+			eee_adv, eee_adv);
+		rv |= hsl_phy_modify_mmd(dev_id, phy_addr, A_FALSE,
+			MALIBU_PHY_MMD3_NUM, MALIBU_PHY_MMD3_ADDR_CLD_CTRL5,
+			BIT(14), 0);
+		rv |= hsl_phy_modify_mmd(dev_id, phy_addr, A_FALSE,
+			MALIBU_PHY_MMD3_NUM, MALIBU_PHY_MMD3_ADDR_CLD_CTRL3,
+			BIT(15), 0);
+		rv |= hsl_phy_mii_reg_write(dev_id, phy_addr, MALIBU_PHY_CONTROL,
+			0x9040);
+		rv |= hsl_phy_modify_debug(dev_id, phy_addr,
+			MALIBU_DEBUG_PHY_HIBERNATION_CTRL, BIT(15), BIT(15));
+		rv |= hsl_phy_modify_mmd(dev_id, phy_addr, A_FALSE,
+			MALIBU_PHY_MMD7_NUM, MALIBU_PHY_MMD7_DAC_CTRL,
+			MALIBU_DAC_CTRL_MASK, MALIBU_DAC_CTRL_VALUE);
+		rv |= hsl_phy_modify_mmd(dev_id, phy_addr, A_FALSE,
+			MALIBU_PHY_MMD7_NUM, MALIBU_PHY_MMD7_LED_1000_CTRL1,
+			MALIBU_LED_1000_CTRL1_100_10_MASK,
+			MALIBU_LED_1000_CTRL1_100_10_MASK);
+		rv |= hsl_phy_modify_mii(dev_id, phy_addr, MALIBU_AUTONEG_ADVERT,
+			MALIBU_EXTENDED_NEXT_PAGE_EN, 0);
+	}
+
+	if (!phy_cnt || first_phy_addr == MAX_PHY_ADDR)
+		return rv;
+
+	if ((phy_cnt == QCA8072_PHY_NUM) && (TO_PHY_ADDR(first_phy_addr) >= 0x3))
+		first_phy_addr -= 0x3;
+
+	/* Restore the old SSDK Malibu PSGMII init sequence before link setup. */
+	rv |= hsl_phy_mmd_reg_write(dev_id,
+		first_phy_addr + MALIBU_PSGMII_PHY_ADDR, A_FALSE,
+		MALIBU_PHY_MMD1_NUM, MALIBU_PSGMII_MODE_CTRL,
+		MALIBU_PHY_PSGMII_MODE_CTRL_ADJUST_VALUE);
+	rv |= hsl_phy_mii_reg_write(dev_id,
+		first_phy_addr + MALIBU_PSGMII_PHY_ADDR,
+		MALIBU_PSGMII_TX_DRIVER_1_CTRL,
+		MALIBU_PHY_PSGMII_REDUCE_SERDES_TX_AMP);
+	rv |= hsl_phy_modify_mmd(dev_id, first_phy_addr + MALIBU_PHY_MAX_ADDR_INC,
+		A_FALSE, MALIBU_PHY_MMD3_NUM,
+		MALIBU_PHY_MMD3_ADDR_REMOTE_LOOPBACK_CTRL, BIT(1), 0);
+
+	if (rv != SW_OK)
+		SSDK_WARN("malibu phy hw init fallback failed, rv=%d\n", rv);
+	else
+		SSDK_INFO("malibu phy hw init fallback on port_bmp 0x%x\n",
+			malibu_port_bmp);
+
+	return rv;
+}
