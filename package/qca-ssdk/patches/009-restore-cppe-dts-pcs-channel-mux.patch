@@ -343,6 +343,20 @@ ssdk_dts_netdev_switch_find_by_devid(a_u
 	return NULL;
 }
 
+a_uint32_t ssdk_dts_port3_pcs_channel_get(a_uint32_t dev_id)
+{
+	ssdk_dt_cfg* cfg = NULL;
+
+	if (dev_id >= SW_MAX_NR_DEV)
+		return 0;
+
+	cfg = ssdk_dt_global.ssdk_dt_switch_nodes[dev_id];
+	if (cfg == NULL)
+		return 0;
+
+	return cfg->port3_pcs_channel;
+}
+
 #if defined(CONFIG_OF) && (LINUX_VERSION_CODE >= KERNEL_VERSION(3,14,0))
 static void ssdk_dt_parse_mac_mode(a_uint32_t dev_id,
 		struct device_node *switch_node, ssdk_init_cfg *cfg)
@@ -377,5 +391,25 @@ static void ssdk_dt_parse_mac_mode(a_uin
 	return;
 }
+
+static void ssdk_dt_parse_port3_pcs_channel(a_uint32_t dev_id,
+		struct device_node *switch_node, ssdk_init_cfg *cfg)
+{
+	a_uint32_t port3_pcs_channel = 0;
+
+	if (of_property_read_u32(switch_node, "port3_pcs_channel",
+			&port3_pcs_channel)) {
+		ssdk_dt_global.ssdk_dt_switch_nodes[dev_id]->port3_pcs_channel = 0;
+		SSDK_INFO("port3_pcs_channel doesn't exist, use phyid auto selection\n");
+	} else {
+		ssdk_dt_global.ssdk_dt_switch_nodes[dev_id]->port3_pcs_channel =
+			port3_pcs_channel;
+		SSDK_INFO("port3_pcs_channel = %u\n",
+			ssdk_dt_global.ssdk_dt_switch_nodes[dev_id]->port3_pcs_channel);
+	}
+
+	return;
+}
