--- a/src/hsl/phy/hsl_phy.c
+++ b/src/hsl/phy/hsl_phy.c
@@ -17,6 +17,7 @@
 #ifdef IN_SFP_PHY
 #include <sfp_phy.h>
 #endif
+#include <linux/delay.h>
 #include <linux/of_gpio.h>
 /*qca808x_start*/
 #include "sw.h"
@@ -48,6 +48,35 @@ phy_driver_instance_t ssdk_phy_driver[]
 /*qca808x_start*/
 	{MAX_PHY_CHIP, {0}, NULL, NULL, NULL}
 };
+
+#ifndef MALIBU_PSGMII_PHY_ADDR
+#define MALIBU_PSGMII_PHY_ADDR 0x5
+#endif
+#ifndef MALIBU_PSGMII_MODE_CTRL
+#define MALIBU_PSGMII_MODE_CTRL 0x6d
+#endif
+#ifndef MALIBU_PHY_PSGMII_MODE_CTRL_ADJUST_VALUE
+#define MALIBU_PHY_PSGMII_MODE_CTRL_ADJUST_VALUE 0x220c
+#endif
+#ifndef MALIBU_PSGMII_TX_DRIVER_1_CTRL
+#define MALIBU_PSGMII_TX_DRIVER_1_CTRL 0xb
+#endif
+#ifndef MALIBU_PHY_PSGMII_REDUCE_SERDES_TX_AMP
+#define MALIBU_PHY_PSGMII_REDUCE_SERDES_TX_AMP 0x8a
+#endif
+#ifndef MALIBU_MODE_CHANAGE_RESET
+#define MALIBU_MODE_CHANAGE_RESET 0x0
+#endif
+#ifndef MALIBU_MODE_RESET_DEFAULT_VALUE
+#define MALIBU_MODE_RESET_DEFAULT_VALUE 0x5f
+#endif
+#ifndef MALIBU_MODE_RESET_REG
+#define MALIBU_MODE_RESET_REG 0x0
+#endif
+#ifndef MALIBU_PHY_MMD1_NUM
+#define MALIBU_PHY_MMD1_NUM 1
+#endif
+
 sw_error_t hsl_phy_api_ops_register(phy_type_t phy_type, hsl_phy_ops_t * phy_api_ops)
 {
 
@@ -512,16 +541,44 @@ hsl_port_phy_serdes_reset(a_uint32_t dev
 {
 	int i = 0;
 	sw_error_t rv = SW_OK;
+	a_uint32_t first_phy_addr = MAX_PHY_ADDR, phy_addr = 0, phy_cnt = 0;
 
 	for (i = 0; i < SW_MAX_NR_PORT; i++)
 	{
 		if (phy_info[dev_id]->phy_type[i] == MALIBU_PHY_CHIP)
 		{
 			HSL_PORT_PHY_EXT_API_RUN(function_reset, dev_id, i,
 				(a_uint32_t)SERDES_RESET);
+			break;
 		}
 	}
 
+	for (i = 0; i < SW_MAX_NR_PORT; i++)
+	{
+		if (phy_info[dev_id]->phy_type[i] != MALIBU_PHY_CHIP)
+			continue;
+
+		phy_addr = qca_ssdk_port_to_phy_addr(dev_id, i);
+		if (phy_addr < first_phy_addr)
+			first_phy_addr = phy_addr;
+		phy_cnt++;
+	}
+
+	if (!phy_cnt || first_phy_addr == MAX_PHY_ADDR)
+		return SW_OK;
+
+	if ((phy_cnt == QCA8072_PHY_NUM) && (TO_PHY_ADDR(first_phy_addr) >= 0x3))
+		first_phy_addr -= 0x3;
+
+	phy_addr = first_phy_addr + MALIBU_PSGMII_PHY_ADDR;
+	hsl_phy_mii_reg_write(dev_id, phy_addr, MALIBU_MODE_RESET_REG,
+		MALIBU_MODE_CHANAGE_RESET);
+	mdelay(100);
+	hsl_phy_mii_reg_write(dev_id, phy_addr, MALIBU_MODE_RESET_REG,
+		MALIBU_MODE_RESET_DEFAULT_VALUE);
+	SSDK_INFO("malibu psgmii serdes reset fallback on phy_addr 0x%x, ext_rv=%d\n",
+		phy_addr, rv);
+
 	return SW_OK;
 }
 
