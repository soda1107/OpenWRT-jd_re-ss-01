--- a/Makefile
+++ b/Makefile
@@ -40,6 +40,22 @@ define Build/Prepare
        $(call Build/Prepare/Default)

+       # --- use ppdragon16/outbound next branch ---
+       rm -rf $(PKG_BUILD_DIR)/outbound
+       git clone https://github.com/ppdragon16/outbound.git $(PKG_BUILD_DIR)/outbound
+       git -C $(PKG_BUILD_DIR)/outbound checkout next
+
+       # ensure go.mod replace is applied
+       cd $(PKG_BUILD_DIR) && go mod edit -replace=github.com/daeuniverse/outbound=./outbound
+       cd $(PKG_BUILD_DIR) && go mod tidy
+
 endef
